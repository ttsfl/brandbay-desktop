# Template for environment variables
# Copy this file to .env.local and fill in your actual credentials
# .env.local is gitignored and won't be committed to the repository

# Apple Developer credentials for macOS notarization
APPLE_ID=your.email@example.com
APPLE_APP_SPECIFIC_PASSWORD=your-app-specific-password
APPLE_TEAM_ID=your-team-id
APPLE_IDENTITY=your-signing-identity

# macOS code signing certificate
CSC_LINK=path/to/certificate.p12
CSC_KEY_PASSWORD=your-certificate-password

# Azure Trusted Signing for Windows code signing
# Auth credentials — from Azure Portal > Microsoft Entra ID > App registrations
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
# Signing account details — from Azure Portal > Trusted Signing Accounts
AZURE_ENDPOINT=https://eus.codesigning.azure.net
AZURE_CODE_SIGNING_ACCOUNT=your-signing-account-name
AZURE_CERT_PROFILE=your-certificate-profile-name
# Publisher name shown in Windows installer "Published by" field
WIN_PUBLISHER_NAME=Your Company Name

# GitHub token for publishing releases
GH_TOKEN=your-github-token
